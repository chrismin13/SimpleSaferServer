[Unit]
Description=SimpleSaferServer Web UI (Flask)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/SimpleSaferServer
ExecStart=/opt/SimpleSaferServer/venv/bin/python -m simple_safer_server --host=0.0.0.0 --port=5000 --no-debug
Restart=on-failure

[Install]
WantedBy=multi-user.target 
